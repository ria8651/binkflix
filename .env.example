# Copy this file to `.env` and edit to taste. Values here are sensible dev defaults.
# `.env` is gitignored; `.env.example` is committed.

# ------------------------------------------------------------------------------
# Required: one or more directories that hold your media.
# Multiple paths are colon-separated (like $PATH). Point at a shows root, a
# movies root, or both together — the scanner decides per-file whether it's a
# movie or episode based on NFO contents and folder layout.
# ------------------------------------------------------------------------------
BINKFLIX_LIBRARY=./media

# ------------------------------------------------------------------------------
# Where the SQLite DB lives. Parent dir is created if missing.
# Keep it repo-local in dev so it survives reboots and is easy to inspect.
# ------------------------------------------------------------------------------
BINKFLIX_DB=./data/binkflix.db

# ------------------------------------------------------------------------------
# HTTP bind address. If unset, falls back to whatever `dx serve` passes in,
# or 127.0.0.1:8080 standalone. Set this for production or to override dev.
# ------------------------------------------------------------------------------
# BINKFLIX_BIND=0.0.0.0:9356

# ------------------------------------------------------------------------------
# Optional: tracing filter. Defaults to `info,binkflix=debug`.
# ------------------------------------------------------------------------------
# RUST_LOG=info,binkflix=debug
